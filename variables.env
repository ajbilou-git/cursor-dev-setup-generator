# ============================================
# PROJECT — Project identity
# ============================================
PROJECT_NAME=                          # Project name, no spaces (e.g. MyProject, DataPlatform, WebApp)
GITHUB_ORG=                            # GitHub organization or user (e.g. my-company, my-org)
PROTECTED_BRANCH=                      # Branch that agents must never modify (e.g. main, master, develop)
BRANCH_PREFIX_FEATURE=                 # Branch prefix for new features (e.g. feat/, feature/)
BRANCH_PREFIX_FIX=                     # Branch prefix for bug fixes (e.g. fix/, bugfix/)

# ============================================
# REPOS — Repository names and paths
# Cursor fills these by analyzing the actual code inside each directory,
# NOT from the directory name. Leave empty for repo types that don't exist.
# ============================================
REPO_BACK_NAME=                        # Backend repo directory name — detected from code analysis
REPO_BACK_PATH=                        # Backend repo relative path (e.g. my-api, packages/api)
REPO_FRONT_NAME=                       # Frontend repo directory name — detected from code analysis
REPO_FRONT_PATH=                       # Frontend repo relative path (e.g. my-web, apps/web)
REPO_DATA_NAME=                        # Data repo directory name — detected from code analysis
REPO_DATA_PATH=                        # Data repo relative path
REPO_INFRA_NAME=                       # Infra repo directory name — detected from code analysis
REPO_INFRA_PATH=                       # Infra repo relative path
REPO_BOOTSTRAP_NAME=                   # Bootstrap/reference repo name — leave empty if none
REPO_BOOTSTRAP_FULL=                   # Bootstrap repo full org/name (e.g. my-org/infra-bootstrap-reference)

# ============================================
# BACKEND — Backend stack (leave ALL empty if no backend repo detected)
# ============================================
BACK_LANGUAGE=                         # Detected from source code (e.g. Java, Go, C#, Python, Kotlin, TypeScript)
BACK_FRAMEWORK=                        # Detected from dependencies (e.g. Spring Boot, Express, FastAPI, Gin, NestJS)
BACK_FRAMEWORK_VERSION=                # Detected from dependency version
BACK_LANGUAGE_VERSION=                 # Detected from build config or .tool-versions
BACK_BUILD_TOOL=                       # Detected from build file (e.g. Gradle, Maven, npm, go build, cargo)
BACK_LINTER=                           # Detected from linter config files (e.g. checkstyle, spotbugs, eslint)
BACK_LINTER_VERSION=                   # Detected from linter config or dependency
BACK_TEST_FRAMEWORK=                   # Detected from test config (e.g. JUnit, pytest, Jest, go test)
BACK_PACKAGE=                          # Detected from source package declarations (e.g. com.acme.billing)
BACK_DB_TYPE=                          # Detected from dependencies or config (e.g. PostgreSQL, MySQL, MongoDB, MSSQL)
BACK_HEALTH_PATH=                      # Detected from actuator/health route config
BACK_PORT=                             # Detected from server config, docker-compose, or Dockerfile EXPOSE
BACK_DB_PORT=                          # Detected from docker-compose or connection config
BACK_MIGRATION_TOOL=                   # Detected from dependencies (e.g. Flyway, Liquibase, Alembic) — empty if none
BACK_SETUP_CMD=                        # Detected build command to install/compile without tests (e.g. ./gradlew build -x test, mvn install -DskipTests, go build ./...)
BACK_BUILD_CMD=                        # Detected build command with tests (e.g. ./gradlew build, mvn package, go build ./..., dotnet build)
BACK_LINT_CMD=                         # Detected lint command (e.g. ./gradlew checkstyleMain checkstyleTest, golangci-lint run)
BACK_TEST_CMD=                         # Detected test command (e.g. ./gradlew test, go test ./..., dotnet test)
BACK_START_CMD=                        # Detected command to start locally (e.g. make daemon, docker compose up -d)

# ============================================
# FRONTEND — Frontend stack (leave ALL empty if no frontend repo detected)
# ============================================
FRONT_FRAMEWORK=                       # Detected from dependencies (e.g. Angular, React, Vue, Next.js, Svelte)
FRONT_FRAMEWORK_VERSION=               # Detected from package.json dependency version
FRONT_BUILD_TOOL=                      # Detected from lock file (e.g. npm, pnpm, yarn, bun)
FRONT_LINTER=                          # Detected from linter config (e.g. ESLint, Biome)
FRONT_TEST_FRAMEWORK=                  # Detected from test config (e.g. Jest, Vitest, Cypress, Playwright)
FRONT_DESIGN_SYSTEM=                   # Detected from dependencies — leave empty if none
FRONT_PORT=                            # Detected from dev server config or angular.json/vite.config
FRONT_INSTALL_CMD=                     # Detected install command (e.g. npm ci, pnpm install, yarn install, bun install)
FRONT_BUILD_CMD=                       # Detected build command (e.g. npm run build, pnpm build, yarn build)
FRONT_LINT_CMD=                        # Detected lint command (e.g. npm run lint, pnpm lint)
FRONT_TEST_CMD=                        # Detected test command (e.g. npm run test, pnpm test)
FRONT_START_CMD=                       # Detected dev server command (e.g. npm run start, pnpm dev)

# ============================================
# DATA — Data pipeline (leave ALL empty if no data repo detected)
# ============================================
DATA_LANGUAGE_VERSION=                 # Detected from .python-version or pyproject.toml
DATA_PACKAGE_MANAGER=                  # Detected from lock file (e.g. Poetry, pip, conda, pdm, uv)
DATA_LINTER=                           # Detected from config (e.g. Ruff, flake8, pylint, black)
DATA_LINTER_LINE_LENGTH=               # Detected from linter config (e.g. 120, 88)
DATA_TEST_FRAMEWORK=                   # Detected from config (e.g. pytest, unittest)
DATA_OPTIMIZER_PORT=                   # Detected from config — leave empty if none
DATA_SETUP_CMD=                        # Detected install command (e.g. poetry install, pip install -r requirements.txt, uv sync)
DATA_LINT_CMD=                         # Detected lint command (e.g. poetry run ruff check ., flake8, pylint)
DATA_TEST_CMD=                         # Detected test command (e.g. poetry run pytest, python -m pytest)

# ============================================
# INFRA — Infrastructure (leave ALL empty if no infra repo detected)
# ============================================
INFRA_TOOL=                            # Detected from files (e.g. Terraform, Pulumi, CDK, Bicep)
INFRA_TOOL_VERSION=                    # Detected from .terraform-version or config
INFRA_PROVIDER_MAIN=                   # Detected from provider blocks (e.g. azurerm, aws, google)
INFRA_PROVIDER_MAIN_VERSION=           # Detected from provider version constraints
INFRA_PROVIDER_SECONDARY=              # Detected from additional providers — leave empty if none
INFRA_PROVIDER_SECONDARY_VERSION=      # Detected from provider version constraints
INFRA_GH_RUNNER=                       # Detected from .github/workflows/ runs-on (e.g. ubuntu-24.04)
INFRA_CHECKOUT_ACTION=                 # Detected from .github/workflows/ (e.g. actions/checkout@v6)
INFRA_MAX_LINE_LENGTH=                 # Detected from formatter config
INFRA_INDENT_SPACES=                   # Detected from .editorconfig or formatter config

# ============================================
# CLOUD — Cloud provider
# ============================================
CLOUD_PROVIDER=                        # Detected from Terraform/CI/CD configs (e.g. azure, aws, gcp, none)
ACR_NAME=                              # Container registry name (e.g. myprojectacr)
ACR_DOMAIN=                            # Container registry domain (e.g. myprojectacr.azurecr.io)

# ============================================
# ENVIRONMENTS — Application URLs
# ============================================
ENV_DEV_URL=                           # Dev environment URL — leave empty if none
ENV_PROD_URL=                          # Prod environment URL — leave empty if none

# ============================================
# JIRA — Issue tracker
# ============================================
ISSUE_TRACKER=                         # Detected from git log or CI config (e.g. jira, github-issues, linear, none)
JIRA_PROJECT_KEY=                      # Detected from git commit messages or ask (e.g. PROJ, BILL)
JIRA_BASE_URL=                         # Jira base URL (e.g. https://mycompany.atlassian.net)
JIRA_BOARD_ID=                         # Jira board ID — ask dev if not found
JIRA_TRANSITION_IN_PROGRESS=           # Transition ID for "In Progress" — ask dev if not found
JIRA_TRANSITION_TO_REVIEW=             # Transition ID for "To Review" — ask dev if not found
JIRA_DEFAULT_PARENT_TICKET=            # Default parent ticket — leave empty if none
JIRA_ISSUE_TYPE=                       # Default issue type (e.g. Task, Story, Bug)

# ============================================
# CONFLUENCE — Documentation wiki (leave empty if none)
# ============================================
CONFLUENCE_SITE_NAME=                  # Atlassian site name (e.g. mycompany)
CONFLUENCE_SPACE_KEY=                  # Space key (e.g. ENGINEERING)
CONFLUENCE_PAGE_EP=                    # Main project page ID
CONFLUENCE_PAGE_GDD=                   # GDD page ID — leave empty if none
CONFLUENCE_PAGE_ADD=                   # ADD page ID — leave empty if none
CONFLUENCE_PAGE_TECHDOC=               # Technical doc page ID — leave empty if none

# ============================================
# MCP — MCP connector credentials
# ============================================
MCP_GITHUB_PAT=                        # GitHub Personal Access Token for MCP
MCP_ATLASSIAN_EMAIL=                   # Atlassian email for Jira/Confluence MCP
MCP_ATLASSIAN_API_TOKEN=               # Atlassian API token for Jira/Confluence MCP

# ============================================
# NOTIFICATIONS — Webhooks (leave empty if none)
# ============================================
NOTIFICATION_CHANNEL=                  # Notification channel (e.g. teams, slack, none)
TEAMS_WEBHOOK_URL=                     # Microsoft Teams webhook URL
TEAMS_COLOR_APPROVED=                  # Teams card color for approved (e.g. 0078D4)
TEAMS_COLOR_REJECTED=                  # Teams card color for rejected (e.g. FF0000)

# ============================================
# GIT / SSH
# ============================================
SSH_KEY_FILE=                          # Detected from ~/.ssh/ (e.g. id_ed25519, id_rsa, id_github_work)

# ============================================
# LOCAL ENVIRONMENT
# ============================================
SHELL_CONFIG_FILE=                     # Detected from $SHELL (e.g. ~/.zshrc, ~/.bashrc, ~/.config/fish/config.fish)
LOGIN_SHELL_CMD=                       # Detected from $SHELL (e.g. zsh -l -c, bash -l -c)
NPM_AUTH_TOKEN_VAR=                    # Detected from .npmrc (e.g. NPM_TOKEN, GITHUB_TOKEN) — leave empty if no private packages

# ============================================
# CONVENTIONS
# ============================================
CODE_LANGUAGE=                         # Language for code and docs (e.g. EN, FR)
SIGNED_COMMITS=                        # Require signed commits (e.g. true, false)
